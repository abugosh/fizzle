(ns fizzle.core
  (:require [reagent.dom :as rdom]
            [re-frame.core :as rf]))

;; Placeholder app-db (will add game events in next task)
(rf/reg-event-db
  ::init-db
  (fn [_ _]
    {:message "Fizzle loading..."}))

(rf/reg-sub
  ::message
  (fn [db _]
    (:message db)))

(defn app []
  (let [msg @(rf/subscribe [::message])]
    [:div {:style {:padding "20px"}}
     [:h1 "Fizzle"]
     [:p msg]]))

(defn ^:dev/after-load mount-root []
  (rf/clear-subscription-cache!)
  (rdom/render [app] (.getElementById js/document "app")))

(defn init []
  (rf/dispatch-sync [::init-db])
  (mount-root))
