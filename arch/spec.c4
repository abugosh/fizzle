// Fizzle Architecture Specification
// Element kinds map to Lowy layers
specification {
    element manager {
        style { shape rectangle }
    }
    element engine {
        style { shape component }
    }
    element resourceAccessor {
        style { shape storage }
    }
    element boundary {
        style { shape browser }
    }

    relationship blocks
    relationship relatesTo

    tag target
}
