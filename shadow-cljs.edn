;; shadow-cljs configuration
{:source-paths
 ["src/dev"
  "src/main"
  "src/test"]

 :dependencies
 [[datascript "1.7.3"]
  [reagent "1.2.0"]
  [re-frame "1.4.3"]]

 :dev-http {8080 "resources/public"}

 :builds
 {:app
  {:target :browser
   :output-dir "resources/public/js"
   :asset-path "/js"
   :modules {:main {:init-fn fizzle.core/init}}}

  :test
  {:target :node-test
   :output-to "out/test.js"
   :ns-regexp "-test$"
   :autorun true}}}
